# .env.example
# Reference for all environment variables used across setup scripts and
# Kubernetes manifests in this repo.
#
# HOW TO USE
# ----------
# This file is documentation, not a runnable env file. Variables fall into
# two categories:
#
#   A) Shell env vars  — export before running a setup script, or set inline:
#        NODE_IP=1.2.3.4 bash setup/init.sh
#
#   B) Manifest values — copy the placeholder value into the relevant YAML
#        file (noted inline) and commit the change. Never commit real secrets.
#        For production, use the Kubernetes secret bootstrap commands instead.
#
# DO NOT commit a .env file containing real values to version control.

# =============================================================================
# Cluster Bootstrap  (setup/init.sh)
# =============================================================================

# Public IP of the server node.
# Used to construct nip.io hostnames (e.g. argocd.<NODE_IP>.nip.io).
# Auto-detected from cloud instance metadata (AWS/DO) or api.ipify.org if not set.
# Override when metadata is unavailable or you want a specific IP.
# Type: shell env var
NODE_IP=1.2.3.4

# VPN subnet CIDR to allow for SSH and the k3s API server.
# When set, init.sh restricts those ports to VPN peers only and
# exposes the ArgoCD UI via Traefik behind an IP-allowlist middleware.
# Compatible with Tailscale (100.64.0.0/10) and NordVPN Meshnet.
# Omit to skip firewall hardening (useful for quick local testing).
# Type: shell env var
VPN_SUBNET=100.64.0.0/10

# =============================================================================
# Worker Node Join  (setup/worker-init.sh)
# =============================================================================

# k3s API server URL of the server node.
# Retrieved from the server node after init.sh runs.
# REQUIRED when running worker-init.sh.
# Type: shell env var
K3S_URL=https://<server-ip>:6443

# k3s cluster join token.
# Read from /var/lib/rancher/k3s/server/node-token on the server node.
# REQUIRED when running worker-init.sh.
# SECURITY: treat as a secret — anyone with this token can join the cluster.
# Type: shell env var
K3S_TOKEN=<contents of /var/lib/rancher/k3s/server/node-token>

# =============================================================================
# App Scaffolding  (setup/new-app.sh)
# =============================================================================

# Name of the application to scaffold (used for namespace, resource names, labels).
# REQUIRED when running new-app.sh.
# Type: shell env var
APP_NAME=my-api

# Container image for the new app.
# REQUIRED when running new-app.sh.
# Type: shell env var
IMAGE=ghcr.io/org/my-api:latest

# Container and service port exposed by the app.
# Default: 80
# Type: shell env var
PORT=80

# Ingress hostname for the new app.
# Default: <APP_NAME>.<NODE_IP>.nip.io (no DNS setup required)
# Override with a real domain when you have DNS configured.
# Type: shell env var
DOMAIN=my-api.example.com

# =============================================================================
# cert-manager / Let's Encrypt  (k8s/system/cert-manager/cluster-issuers.yaml)
# =============================================================================

# Email address registered with Let's Encrypt for certificate notifications
# (expiry warnings, policy updates).
# Edit directly in cluster-issuers.yaml before applying:
#   email: you@example.com
# Type: manifest value
LETSENCRYPT_EMAIL=you@example.com

# =============================================================================
# Application Secrets  (plain Kubernetes Secrets — example-app)
# =============================================================================
# Secrets are plain Kubernetes Secrets created with kubectl.
# Apps consume them via envFrom in their Deployment (optional: true so pods
# start even if the secret is absent).
#
# Create or update a secret:
#   kubectl create secret generic example-app-secrets -n example-app \
#     --from-literal=MY_KEY=value \
#     --dry-run=client -o yaml | kubectl apply -f -

# Example keys for example-app-secrets:
EXAMPLE_APP_API_KEY=<your-api-key>
EXAMPLE_APP_DB_PASSWORD=<your-db-password>
