# .env.example
# Reference for all environment variables used across setup scripts and
# Kubernetes manifests in this repo.
#
# HOW TO USE
# ----------
# This file is documentation, not a runnable env file. Variables fall into
# two categories:
#
#   A) Shell env vars  — export before running a setup script, or set inline:
#        NODE_IP=1.2.3.4 bash setup/init.sh
#
#   B) Manifest values — copy the placeholder value into the relevant YAML
#        file (noted inline) and commit the change. Never commit real secrets.
#        For production, use the Kubernetes secret bootstrap commands instead.
#
# DO NOT commit a .env file containing real values to version control.

# =============================================================================
# Cluster Bootstrap  (setup/init.sh)
# =============================================================================

# Public IP of the server node.
# Used to construct nip.io hostnames (e.g. argocd.<NODE_IP>.nip.io).
# Auto-detected from cloud instance metadata (AWS/DO) or api.ipify.org if not set.
# Override when metadata is unavailable or you want a specific IP.
# Type: shell env var
NODE_IP=1.2.3.4

# VPN subnet CIDR to allow for SSH and the k3s API server.
# When set, init.sh restricts those ports to VPN peers only and
# exposes the ArgoCD UI via Traefik behind an IP-allowlist middleware.
# Compatible with Tailscale (100.64.0.0/10) and NordVPN Meshnet.
# Omit to skip firewall hardening (useful for quick local testing).
# Type: shell env var
VPN_SUBNET=100.64.0.0/10

# =============================================================================
# Worker Node Join  (setup/worker-init.sh)
# =============================================================================

# k3s API server URL of the server node.
# Retrieved from the server node after init.sh runs.
# REQUIRED when running worker-init.sh.
# Type: shell env var
K3S_URL=https://<server-ip>:6443

# k3s cluster join token.
# Read from /var/lib/rancher/k3s/server/node-token on the server node.
# REQUIRED when running worker-init.sh.
# SECURITY: treat as a secret — anyone with this token can join the cluster.
# Type: shell env var
K3S_TOKEN=<contents of /var/lib/rancher/k3s/server/node-token>

# =============================================================================
# App Scaffolding  (setup/new-app.sh)
# =============================================================================

# Name of the application to scaffold (used for namespace, resource names, labels).
# REQUIRED when running new-app.sh.
# Type: shell env var
APP_NAME=my-api

# Container image for the new app.
# REQUIRED when running new-app.sh.
# Type: shell env var
IMAGE=ghcr.io/org/my-api:latest

# Container and service port exposed by the app.
# Default: 80
# Type: shell env var
PORT=80

# Ingress hostname for the new app.
# Default: <APP_NAME>.<NODE_IP>.nip.io (no DNS setup required)
# Override with a real domain when you have DNS configured.
# Type: shell env var
DOMAIN=my-api.example.com

# =============================================================================
# cert-manager / Let's Encrypt  (k8s/system/cert-manager/cluster-issuers.yaml)
# =============================================================================

# Email address registered with Let's Encrypt for certificate notifications
# (expiry warnings, policy updates).
# Edit directly in cluster-issuers.yaml before applying:
#   email: you@example.com
# Type: manifest value
LETSENCRYPT_EMAIL=you@example.com

# =============================================================================
# Infisical — Encryption & Auth  (k8s/system/infisical/helmrelease.yaml)
# =============================================================================
# These values are inlined into the Helm values in helmrelease.yaml.
# For production, move them to a pre-created Kubernetes Secret and reference
# it via kubeSecretRef instead of inline env vars.
#
# Generate both with: openssl rand -hex 32

# AES-256 key used by Infisical to encrypt secrets at rest.
# REQUIRED — replace REPLACE_ME_32_CHAR_HEX in helmrelease.yaml.
# SECURITY: rotating this key re-encrypts all stored secrets; never lose it.
# Generate: openssl rand -hex 32
# Type: manifest value → helmrelease.yaml → infisical.env.ENCRYPTION_KEY
INFISICAL_ENCRYPTION_KEY=REPLACE_ME_32_CHAR_HEX

# JWT signing secret used by Infisical for user sessions.
# REQUIRED — replace REPLACE_ME_32_CHAR_HEX in helmrelease.yaml.
# SECURITY: changing this invalidates all active Infisical user sessions.
# Generate: openssl rand -hex 32
# Type: manifest value → helmrelease.yaml → infisical.env.AUTH_SECRET
INFISICAL_AUTH_SECRET=REPLACE_ME_32_CHAR_HEX

# =============================================================================
# Infisical — PostgreSQL  (k8s/system/infisical/helmrelease.yaml)
# =============================================================================

# Password for the Infisical PostgreSQL database user.
# REQUIRED — replace REPLACE_DB_PASSWORD in TWO places in helmrelease.yaml:
#   1. infisical.env.DB_CONNECTION_URI  (the connection string)
#   2. postgresql.auth.password
# For production, use postgresql.auth.existingSecret instead.
# Generate: openssl rand -base64 24 | tr -d /=+ | head -c 32
# Type: manifest value → helmrelease.yaml
INFISICAL_DB_PASSWORD=REPLACE_DB_PASSWORD

# =============================================================================
# Infisical — Machine Identity  (kubectl secret + cluster-secret-store.yaml)
# =============================================================================
# ESO uses a Kubernetes Secret named "infisical-credentials" to authenticate
# to Infisical. Create this secret BEFORE ArgoCD syncs the ClusterSecretStore:
#
#   kubectl create secret generic infisical-credentials \
#     -n external-secrets \
#     --from-literal=clientId=<INFISICAL_CLIENT_ID> \
#     --from-literal=clientSecret=<INFISICAL_CLIENT_SECRET>
#
# Obtain from: Infisical UI → Project Settings → Machine Identities → Create
# Grant the identity "read" access on the environments ESO will pull from.

# Machine Identity client ID from Infisical.
# Type: kubectl secret value (not a file you edit)
INFISICAL_CLIENT_ID=<machine-identity-client-id>

# Machine Identity client secret from Infisical.
# SECURITY: treat as a password — rotate via the Infisical UI if exposed.
# Type: kubectl secret value (not a file you edit)
INFISICAL_CLIENT_SECRET=<machine-identity-client-secret>

# =============================================================================
# Infisical — Project Scope  (k8s/system/infisical/cluster-secret-store.yaml)
# =============================================================================

# Slug of the Infisical project to read secrets from.
# Find it in: Infisical UI → Project Settings → Overview → Project Slug.
# Edit directly in cluster-secret-store.yaml:
#   secretsScope.projectSlug: "my-project"
# Type: manifest value
INFISICAL_PROJECT_SLUG=my-project

# Environment slug within the project (e.g. prod, staging, dev).
# Edit directly in cluster-secret-store.yaml:
#   secretsScope.envSlug: "prod"
# Type: manifest value
INFISICAL_ENV_SLUG=prod

# =============================================================================
# Application Secrets  (pulled from Infisical by ESO — example-app)
# =============================================================================
# These are not set locally. They live in Infisical and are injected into pods
# via ExternalSecret / ClusterExternalSecret. Shown here as documentation of
# what secret keys must exist in Infisical for the example-app to start.
#
# In Infisical, create secrets with these exact key names under your project:

# API key for the example-app service.
# Infisical key: EXAMPLE_APP_API_KEY
# Injected as env var: API_KEY
EXAMPLE_APP_API_KEY=<stored in Infisical>

# Database password for the example-app.
# Infisical key: EXAMPLE_APP_DB_PASSWORD
# Injected as env var: DB_PASSWORD
EXAMPLE_APP_DB_PASSWORD=<stored in Infisical>

# Global secrets are defined in k8s/apps/_global/cluster-external-secret.yaml.
# Add any shared keys (e.g. GLOBAL_API_KEY) to Infisical and reference them
# there so they are injected into all labeled namespaces automatically.
